DOMAIN_NAME=your_domain_name

# MARIADB SETUP
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=wordpress
MARIADB_USER=your_db_user

# WORDPRESS SETUP
WP_VERSION=6.9.4
WP_TITLE=your_wp_title
WP_PORT=9000
WP_ADMIN_USER=your_wp_admin_login
WP_ADMIN_EMAIL=your_wp_admin_email
WP_USER=your_wp_user_login
WP_USER_EMAIL=your_wp_user_email

# NGINX SETUP
NGINX_PORT=443
NGINX_HOST_PORT=443

# REDIS
REDIS_PORT=6379

# FTP
FTP_PORT=21
FTP_PASV_MIN_PORT=40000
FTP_PASV_MAX_PORT=40005
FTP_USER=your_ftp_user

# STATIC (LIGHTTPD)
STATIC_PORT=80
STATIC_HOST_PORT=8081

# ADMINER
ADMINER_VERSION=5.4.2
ADMINER_PORT=8080
ADMINER_HOST_PORT=8080

# ARCANE
ARCANE_VERSION=1.18.1
ARCANE_PORT=3552
ARCANE_HOST_PORT=3552

# HAPROXY
HAPROXY_HOST=haproxy
HAPROXY_PORT=2375
